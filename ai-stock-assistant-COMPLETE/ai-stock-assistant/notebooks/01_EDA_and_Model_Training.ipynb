   "source": [
    "# AI Stock Market Forecasting System\n",
    "## Exploratory Data Analysis + Model Training Notebook\n",
    "\n",
    "This notebook covers:\n",
    "1. Data fetching and EDA\n",
    "2. Technical indicator visualization\n",
    "3. LSTM training and evaluation\n",
    "4. Prophet forecast\n",
    "5. ARIMA with ADF test\n",
    "6. Model comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Install dependencies ──\n",
    "# !pip install yfinance prophet statsmodels pmdarima tensorflow ta plotly"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('dark_background')\n",
    "ACCENT = '#00e5a0'\n",
    "ACCENT2 = '#00b8ff'\n",
    "DANGER = '#ff3860'\n",
    "\n",
    "# ── Config ──\n",
    "SYMBOL = '^NSEI'        # NIFTY 50\n",
    "PERIOD = '2y'\n",
    "FORECAST_DAYS = 7\n",
    "\n",
    "print(f'Fetching data for: {SYMBOL}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 1: DATA FETCHING\n",
    "# ═══════════════════════════════════\n",
    "df = yf.download(SYMBOL, period=PERIOD, interval='1d', progress=False)\n",
    "\n",
    "if isinstance(df.columns, pd.MultiIndex):\n",
    "    df.columns = df.columns.get_level_values(0)\n",
    "\n",
    "print(f'Shape: {df.shape}')\n",
    "print(f'Date range: {df.index[0].date()} → {df.index[-1].date()}')\n",
    "print(f'\\nBasic stats:')\n",
    "df[['Open', 'High', 'Low', 'Close', 'Volume']].describe().round(2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 2: PRICE VISUALIZATION\n",
    "# ═══════════════════════════════════\n",
    "\n",
    "# Compute indicators\n",
    "df['SMA_50']  = df['Close'].rolling(50).mean()\n",
    "df['SMA_200'] = df['Close'].rolling(200).mean()\n",
    "df['BB_Mid']  = df['Close'].rolling(20).mean()\n",
    "df['BB_Std']  = df['Close'].rolling(20).std()\n",
    "df['BB_Up']   = df['BB_Mid'] + 2 * df['BB_Std']\n",
    "df['BB_Low']  = df['BB_Mid'] - 2 * df['BB_Std']\n",
    "\n",
    "# RSI\n",
    "delta = df['Close'].diff()\n",
    "gain  = delta.clip(lower=0)\n",
    "loss  = -delta.clip(upper=0)\n",
    "avg_gain = gain.ewm(com=13, min_periods=14).mean()\n",
    "avg_loss = loss.ewm(com=13, min_periods=14).mean()\n",
    "df['RSI'] = 100 - 100 / (1 + avg_gain / avg_loss)\n",
    "\n",
    "# MACD\n",
    "df['MACD']     = df['Close'].ewm(span=12).mean() - df['Close'].ewm(span=26).mean()\n",
    "df['MACD_Sig'] = df['MACD'].ewm(span=9).mean()\n",
    "df['MACD_Hist']= df['MACD'] - df['MACD_Sig']\n",
    "\n",
    "# Plot\n",
    "fig = make_subplots(rows=3, cols=1, shared_xaxes=True,\n",
    "    row_heights=[0.6, 0.2, 0.2],\n",
    "    subplot_titles=['Price + Bollinger Bands', 'RSI (14)', 'MACD'])\n",
    "\n",
    "# Price\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['Close'], name='Close', line=dict(color=ACCENT2, width=2)), row=1, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['SMA_50'],  name='SMA50',  line=dict(color='#ffb300', dash='dot', width=1.5)), row=1, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['SMA_200'], name='SMA200', line=dict(color='#a78bfa', dash='dash', width=1.5)), row=1, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['BB_Up'],  name='BB Upper', line=dict(color='rgba(0,229,160,0.3)', width=1), fill=None), row=1, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['BB_Low'], name='BB Lower', line=dict(color='rgba(0,229,160,0.3)', width=1), fill='tonexty', fillcolor='rgba(0,229,160,0.05)'), row=1, col=1)\n",
    "\n",
    "# RSI\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['RSI'], name='RSI', line=dict(color='#a78bfa', width=2)), row=2, col=1)\n",
    "fig.add_hline(y=70, line_dash='dot', line_color='rgba(255,56,96,0.5)', row=2, col=1)\n",
    "fig.add_hline(y=30, line_dash='dot', line_color='rgba(0,229,160,0.5)', row=2, col=1)\n",
    "\n",
    "# MACD\n",
    "colors = ['rgba(0,229,160,0.7)' if v >= 0 else 'rgba(255,56,96,0.7)' for v in df['MACD_Hist'].fillna(0)]\n",
    "fig.add_trace(go.Bar(x=df.index, y=df['MACD_Hist'], name='Histogram', marker_color=colors), row=3, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['MACD'],     name='MACD',   line=dict(color=ACCENT2, width=2)), row=3, col=1)\n",
    "fig.add_trace(go.Scatter(x=df.index, y=df['MACD_Sig'], name='Signal', line=dict(color=DANGER, width=1.5, dash='dot')), row=3, col=1)\n",
    "\n",
    "fig.update_layout(\n",
    "    title=f'{SYMBOL} — Technical Analysis Dashboard',\n",
    "    template='plotly_dark',\n",
    "    paper_bgcolor='#0d1117',\n",
    "    plot_bgcolor='#0d1117',\n",
    "    height=700, showlegend=True,\n",
    "    font=dict(family='monospace', size=11)\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 3: LSTM MODEL\n",
    "# ═══════════════════════════════════\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import LSTM, Dense, Dropout\n",
    "from tensorflow.keras.callbacks import EarlyStopping\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_error\n",
    "import math\n",
    "\n",
    "print(f'TensorFlow version: {tf.__version__}')\n",
    "\n",
    "WINDOW = 60\n",
    "close  = df['Close'].values.reshape(-1, 1)\n",
    "\n",
    "# Scale\n",
    "scaler = MinMaxScaler()\n",
    "scaled = scaler.fit_transform(close)\n",
    "\n",
    "# Split\n",
    "split   = int(len(scaled) * 0.8)\n",
    "train   = scaled[:split]\n",
    "test_in = scaled[split - WINDOW:]\n",
    "\n",
    "# Sequences\n",
    "def make_seq(data, window):\n",
    "    X, y = [], []\n",
    "    for i in range(window, len(data)):\n",
    "        X.append(data[i-window:i, 0])\n",
    "        y.append(data[i, 0])\n",
    "    return np.array(X).reshape(-1, window, 1), np.array(y)\n",
    "\n",
    "X_train, y_train = make_seq(train,   WINDOW)\n",
    "X_test,  y_test  = make_seq(test_in, WINDOW)\n",
    "\n",
    "print(f'Train: {X_train.shape} | Test: {X_test.shape}')\n",
    "\n",
    "# Build model\n",
    "model = Sequential([\n",
    "    LSTM(128, return_sequences=True, input_shape=(WINDOW, 1)),\n",
    "    Dropout(0.2),\n",
    "    LSTM(64, return_sequences=False),\n",
    "    Dropout(0.2),\n",
    "    Dense(32, activation='relu'),\n",
    "    Dense(1),\n",
    "])\n",
    "model.compile(optimizer='adam', loss='mse')\n",
    "model.summary()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train\n",
    "history = model.fit(\n",
    "    X_train, y_train,\n",
    "    epochs=30,\n",
    "    batch_size=32,\n",
    "    validation_split=0.1,\n",
    "    callbacks=[EarlyStopping(patience=5, restore_best_weights=True)],\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "# Plot training loss\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.plot(history.history['loss'],     label='Train Loss', color=ACCENT2)\n",
    "plt.plot(history.history['val_loss'], label='Val Loss',   color=DANGER)\n",
    "plt.title('LSTM Training Loss')\n",
    "plt.xlabel('Epoch'); plt.ylabel('MSE Loss')\n",
    "plt.legend(); plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Predict + metrics\n",
    "pred_s   = model.predict(X_test)\n",
    "pred     = scaler.inverse_transform(pred_s).flatten()\n",
    "actual   = scaler.inverse_transform(y_test.reshape(-1,1)).flatten()\n",
    "\n",
    "rmse_lstm = math.sqrt(mean_squared_error(actual, pred))\n",
    "mae_lstm  = mean_absolute_error(actual, pred)\n",
    "mape_lstm = np.mean(np.abs((actual - pred) / actual)) * 100\n",
    "\n",
    "print(f'LSTM Performance:')\n",
    "print(f'  RMSE: {rmse_lstm:.4f}')\n",
    "print(f'  MAE:  {mae_lstm:.4f}')\n",
    "print(f'  MAPE: {mape_lstm:.2f}%')\n",
    "\n",
    "# Plot actual vs predicted\n",
    "test_dates = df.index[split:]\n",
    "plt.figure(figsize=(14, 5))\n",
    "plt.plot(test_dates[:len(actual)], actual, label='Actual',    color='#8b949e', linewidth=1.5)\n",
    "plt.plot(test_dates[:len(pred)],   pred,   label='Predicted', color=ACCENT,    linewidth=2)\n",
    "plt.title(f'LSTM — Actual vs Predicted | RMSE={rmse_lstm:.2f} | MAPE={mape_lstm:.2f}%')\n",
    "plt.xlabel('Date'); plt.ylabel('Price'); plt.legend()\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 4: PROPHET FORECAST\n",
    "# ═══════════════════════════════════\n",
    "from prophet import Prophet\n",
    "\n",
    "prophet_df = df[['Close']].reset_index()\n",
    "prophet_df.columns = ['ds', 'y']\n",
    "prophet_df['ds'] = pd.to_datetime(prophet_df['ds']).dt.tz_localize(None)\n",
    "\n",
    "split_p = int(len(prophet_df) * 0.8)\n",
    "train_p = prophet_df[:split_p]\n",
    "\n",
    "pm = Prophet(yearly_seasonality=True, weekly_seasonality=True,\n",
    "             daily_seasonality=False, changepoint_prior_scale=0.05)\n",
    "pm.fit(train_p)\n",
    "\n",
    "future    = pm.make_future_dataframe(periods=split_p + FORECAST_DAYS, freq='B')\n",
    "fc_prophet= pm.predict(future)\n",
    "\n",
    "# Metrics on test\n",
    "test_p = prophet_df[split_p:]\n",
    "pred_p = fc_prophet[split_p:split_p+len(test_p)]['yhat'].values\n",
    "act_p  = test_p['y'].values[:len(pred_p)]\n",
    "\n",
    "rmse_p = math.sqrt(mean_squared_error(act_p, pred_p))\n",
    "mae_p  = mean_absolute_error(act_p, pred_p)\n",
    "\n",
    "print(f'Prophet Performance:')\n",
    "print(f'  RMSE: {rmse_p:.4f}')\n",
    "print(f'  MAE:  {mae_p:.4f}')\n",
    "\n",
    "# Plot with confidence intervals\n",
    "fig2 = pm.plot(fc_prophet, figsize=(14, 5))\n",
    "plt.title(f'Prophet Forecast | RMSE={rmse_p:.2f}')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 5: ARIMA + ADF TEST\n",
    "# ═══════════════════════════════════\n",
    "from statsmodels.tsa.stattools import adfuller\n",
    "import pmdarima as pm_arima\n",
    "\n",
    "log_close = np.log(df['Close'].dropna())\n",
    "\n",
    "# ADF test\n",
    "adf = adfuller(log_close, autolag='AIC')\n",
    "print('=== ADF Test Results ===')\n",
    "print(f'Test Statistic:  {adf[0]:.4f}')\n",
    "print(f'P-value:         {adf[1]:.4f}')\n",
    "print(f'Critical (1%):   {adf[4][\"1%\"]:.4f}')\n",
    "print(f'Critical (5%):   {adf[4][\"5%\"]:.4f}')\n",
    "print(f'Stationary:      {adf[1] < 0.05}')\n",
    "\n",
    "# Auto ARIMA\n",
    "split_a  = int(len(log_close) * 0.8)\n",
    "train_a  = log_close[:split_a]\n",
    "\n",
    "print('\\nRunning auto_arima...')\n",
    "auto = pm_arima.auto_arima(train_a, start_p=1, start_q=1, max_p=4, max_q=4,\n",
    "    seasonal=False, stepwise=True, suppress_warnings=True, error_action='ignore')\n",
    "print(f'Best order: ARIMA{auto.order}')\n",
    "print(f'AIC: {auto.aic():.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 6: MODEL COMPARISON\n",
    "# ═══════════════════════════════════\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "results = {\n",
    "    'LSTM':    {'RMSE': rmse_lstm, 'MAE': mae_lstm, 'MAPE': mape_lstm},\n",
    "    'Prophet': {'RMSE': rmse_p,    'MAE': mae_p,    'MAPE': 0},  # Fill from above\n",
    "}\n",
    "\n",
    "df_res = pd.DataFrame(results).T\n",
    "print('\\n=== Model Comparison ===')\n",
    "print(df_res.round(4))\n",
    "\n",
    "best = df_res['RMSE'].idxmin()\n",
    "print(f'\\n✓ Best model by RMSE: {best}')\n",
    "\n",
    "# Bar chart\n",
    "fig, axes = plt.subplots(1, 3, figsize=(14, 5))\n",
    "metrics = ['RMSE', 'MAE', 'MAPE']\n",
    "colors_bar = [ACCENT, ACCENT2, '#ffb300']\n",
    "\n",
    "for ax, metric, col in zip(axes, metrics, colors_bar):\n",
    "    vals  = df_res[metric].values\n",
    "    names = df_res.index\n",
    "    bars  = ax.bar(names, vals, color=[col if n==best else '#30363d' for n in names], width=0.5)\n",
    "    ax.set_title(metric, fontsize=13)\n",
    "    ax.set_ylabel('Value')\n",
    "    for bar, v in zip(bars, vals):\n",
    "        ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+0.001,\n",
    "                f'{v:.3f}', ha='center', va='bottom', fontsize=10)\n",
    "\n",
    "plt.suptitle('Model Comparison — Lower is Better', fontsize=14, y=1.02)\n",
    "plt.tight_layout(); plt.show()"
   ]
  }
 ]
}"
