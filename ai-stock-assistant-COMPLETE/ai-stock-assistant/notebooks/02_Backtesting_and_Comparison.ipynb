    "# AI Stock Forecasting — Model Comparison & Deep Dive\n",
    "\n",
    "**Notebook 2 of 2**\n",
    "\n",
    "Covers:\n",
    "1. Multi-stock backtesting framework\n",
    "2. Walk-forward validation\n",
    "3. Directional accuracy measurement\n",
    "4. Feature importance analysis\n",
    "5. Sharpe ratio of signal-based strategy\n",
    "6. Confusion matrix for BUY/SELL signal quality"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_error, confusion_matrix\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "import math\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.style.use('dark_background')\n",
    "ACCENT  = '#00e5a0'\n",
    "ACCENT2 = '#00b8ff'\n",
    "DANGER  = '#ff3860'\n",
    "WARN    = '#ffb300'\n",
    "\n",
    "# Stocks to test\n",
    "STOCKS = {\n",
    "    'NIFTY':    '^NSEI',\n",
    "    'TCS':      'TCS.NS',\n",
    "    'RELIANCE': 'RELIANCE.NS',\n",
    "    'AAPL':     'AAPL',\n",
    "}\n",
    "PERIOD = '2y'\n",
    "print('Stocks configured:', list(STOCKS.keys()))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 1: FETCH ALL STOCKS\n",
    "# ═══════════════════════════════════\n",
    "stock_data = {}\n",
    "for name, ticker in STOCKS.items():\n",
    "    df = yf.download(ticker, period=PERIOD, progress=False)\n",
    "    if isinstance(df.columns, pd.MultiIndex):\n",
    "        df.columns = df.columns.get_level_values(0)\n",
    "    stock_data[name] = df.dropna()\n",
    "    print(f'{name:10} → {len(df)} rows | Latest close: {df[\"Close\"].iloc[-1]:.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 2: NORMALIZED PRICE CHART\n",
    "# ═══════════════════════════════════\n",
    "# Base-100 normalize all stocks for visual comparison\n",
    "fig = go.Figure()\n",
    "\n",
    "colors = [ACCENT, ACCENT2, WARN, DANGER]\n",
    "for (name, df), color in zip(stock_data.items(), colors):\n",
    "    normalized = (df['Close'] / df['Close'].iloc[0]) * 100\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=df.index, y=normalized,\n",
    "        name=name, line=dict(color=color, width=2)\n",
    "    ))\n",
    "\n",
    "fig.add_hline(y=100, line_dash='dot', line_color='rgba(255,255,255,0.2)')\n",
    "fig.update_layout(\n",
    "    title='Normalized Price Performance (Base 100)',\n",
    "    template='plotly_dark', paper_bgcolor='#0d1117', plot_bgcolor='#0d1117',\n",
    "    height=400, yaxis_title='Index Value',\n",
    "    font=dict(family='monospace', size=11)\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
