   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 3: WALK-FORWARD VALIDATION\n",
    "# ═══════════════════════════════════\n",
    "# Sliding-window RMSE across 5 folds — more realistic than single split\n",
    "\n",
    "def walk_forward_rmse(close: pd.Series, n_folds: int = 5, window: int = 60) -> list:\n",
    "    \"\"\"Walk-forward validation: train on expanding window, test on next 30 days.\"\"\"\n",
    "    prices    = close.values.reshape(-1, 1)\n",
    "    fold_size = len(prices) // (n_folds + 1)\n",
    "    rmse_list = []\n",
    "\n",
    "    for fold in range(n_folds):\n",
    "        train_end = fold_size * (fold + 1)\n",
    "        test_end  = train_end + fold_size\n",
    "\n",
    "        train = prices[:train_end]\n",
    "        test  = prices[train_end:test_end]\n",
    "\n",
    "        if len(train) < window + 10 or len(test) == 0:\n",
    "            continue\n",
    "\n",
    "        # Simple exponential smoothing as proxy\n",
    "        alpha  = 0.3\n",
    "        smooth = [train[-1][0]]\n",
    "        preds  = []\n",
    "        for v in test.flatten():\n",
    "            pred = smooth[-1]\n",
    "            preds.append(pred)\n",
    "            smooth.append(alpha * v + (1 - alpha) * smooth[-1])\n",
    "\n",
    "        rmse = math.sqrt(mean_squared_error(test.flatten(), preds))\n",
    "        rmse_list.append({'fold': fold + 1, 'rmse': round(rmse, 4), 'train_size': train_end})\n",
    "\n",
    "    return rmse_list\n",
    "\n",
    "\n",
    "print('Walk-Forward Validation Results:')\n",
    "print('=' * 50)\n",
    "for name, df in stock_data.items():\n",
    "    folds = walk_forward_rmse(df['Close'])\n",
    "    avg_rmse = np.mean([f['rmse'] for f in folds])\n",
    "    print(f'{name:10} | Avg RMSE: {avg_rmse:.4f} | Folds: {[f[\"rmse\"] for f in folds]}')"
   ]
  },
  {
   "cell_type": "code",
