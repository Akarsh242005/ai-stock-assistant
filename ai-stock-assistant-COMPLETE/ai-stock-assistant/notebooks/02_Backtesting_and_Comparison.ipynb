    "# ═══════════════════════════════════\n",
    "# SECTION 5: DIRECTIONAL ACCURACY\n",
    "# ═══════════════════════════════════\n",
    "# Measures what % of the time the model correctly predicts UP vs DOWN\n",
    "\n",
    "def directional_accuracy(actuals, predictions):\n",
    "    \"\"\"% of days where predicted direction matches actual direction.\"\"\"\n",
    "    actual_dir = np.sign(np.diff(actuals))\n",
    "    pred_dir   = np.sign(np.diff(predictions))\n",
    "    return np.mean(actual_dir == pred_dir) * 100\n",
    "\n",
    "\n",
    "# Generate naive predictions (yesterday's price)\n",
    "print('Directional Accuracy — Naive (lag-1) Model:')\n",
    "print('=' * 45)\n",
    "for name, df in stock_data.items():\n",
    "    close  = df['Close'].values\n",
    "    actual = close[30:]    # test set\n",
    "    naive  = close[29:-1]  # lag-1 prediction\n",
    "\n",
    "    da = directional_accuracy(actual, naive)\n",
    "    # Naive model is ~50% (random walk)\n",
    "    print(f'{name:10} | Directional Accuracy: {da:.1f}% | Naive baseline: ~50.0%')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 6: FEATURE IMPORTANCE\n",
    "# ═══════════════════════════════════\n",
    "# Train a Random Forest on technical features and plot importance\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "def build_features(df):\n",
    "    \"\"\"Build ML feature matrix from OHLCV + technical indicators.\"\"\"\n",
    "    d = df.copy()\n",
    "    d['Return']       = d['Close'].pct_change()\n",
    "    d['Return_5d']    = d['Close'].pct_change(5)\n",
    "    d['Return_20d']   = d['Close'].pct_change(20)\n",
    "    d['Vol_10']       = d['Return'].rolling(10).std()\n",
    "    d['SMA_ratio']    = d['Close'] / d['Close'].rolling(50).mean()\n",
    "\n",
    "    # RSI\n",
    "    delta = d['Close'].diff()\n",
    "    g = delta.clip(lower=0).ewm(com=13, min_periods=14).mean()\n",
    "    l = (-delta.clip(upper=0)).ewm(com=13, min_periods=14).mean()\n",
    "    d['RSI'] = 100 - 100 / (1 + g / l)\n",
    "\n",
    "    # MACD\n",
    "    d['MACD'] = d['Close'].ewm(span=12).mean() - d['Close'].ewm(span=26).mean()\n",
    "\n",
    "    # Bollinger %B\n",
    "    mid  = d['Close'].rolling(20).mean()\n",
    "    std  = d['Close'].rolling(20).std()\n",
    "    d['BB_pct'] = (d['Close'] - (mid - 2*std)) / (4*std + 1e-8)\n",
    "\n",
    "    # Target: next day UP (1) or DOWN (0)\n",
    "    d['Target'] = (d['Return'].shift(-1) > 0).astype(int)\n",
    "\n",
    "    features = ['Return', 'Return_5d', 'Return_20d', 'Vol_10',\n",
    "                'SMA_ratio', 'RSI', 'MACD', 'BB_pct']\n",
    "    d = d[features + ['Target']].dropna()\n",
    "    return d[features], d['Target']\n",
    "\n",
    "\n",
    "# Use NIFTY\n",
    "df_nifty = stock_data['NIFTY']\n",
    "X, y     = build_features(df_nifty)\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, shuffle=False)\n",
    "\n",
    "rf = RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)\n",
    "rf.fit(X_train, y_train)\n",
    "\n",
    "acc = rf.score(X_test, y_test) * 100\n",
    "print(f'Random Forest directional accuracy on NIFTY: {acc:.1f}%')\n",
    "\n",
    "# Feature importance\n",
    "importances = pd.Series(rf.feature_importances_, index=X.columns).sort_values(ascending=True)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "bars = ax.barh(importances.index, importances.values,\n",
    "               color=[ACCENT if v > importances.median() else '#30363d' for v in importances.values])\n",
    "ax.set_xlabel('Importance Score')\n",
    "ax.set_title('Feature Importance — Random Forest on NIFTY')\n",
    "for bar, val in zip(bars, importances.values):\n",
    "    ax.text(val + 0.002, bar.get_y() + bar.get_height()/2,\n",
    "            f'{val:.3f}', va='center', fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
