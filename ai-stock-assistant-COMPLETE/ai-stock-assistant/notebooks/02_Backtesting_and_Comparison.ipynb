   "outputs": [],
   "source": [
    "# ═══════════════════════════════════\n",
    "# SECTION 4: TECHNICAL SIGNAL BACKTEST\n",
    "# ═══════════════════════════════════\n",
    "# Simulate trading based on RSI + MACD signals and measure P&L\n",
    "\n",
    "def compute_rsi(close, period=14):\n",
    "    delta    = close.diff()\n",
    "    gain     = delta.clip(lower=0).ewm(com=period-1, min_periods=period).mean()\n",
    "    loss     = (-delta.clip(upper=0)).ewm(com=period-1, min_periods=period).mean()\n",
    "    return 100 - (100 / (1 + gain / loss))\n",
    "\n",
    "def backtest_rsi_strategy(df, rsi_buy=35, rsi_sell=65):\n",
    "    \"\"\"Simple RSI mean-reversion strategy.\"\"\"\n",
    "    close    = df['Close'].copy()\n",
    "    rsi      = compute_rsi(close)\n",
    "    returns  = close.pct_change()\n",
    "\n",
    "    position = 0     # 1=long, 0=flat\n",
    "    pnl      = []\n",
    "\n",
    "    for i in range(1, len(close)):\n",
    "        if rsi.iloc[i-1] < rsi_buy:   position = 1   # BUY signal\n",
    "        elif rsi.iloc[i-1] > rsi_sell: position = 0   # SELL signal\n",
    "\n",
    "        daily_ret = returns.iloc[i] * position\n",
    "        pnl.append(daily_ret)\n",
    "\n",
    "    strat_returns = pd.Series(pnl, index=close.index[1:])\n",
    "    buy_hold      = returns.iloc[1:]\n",
    "\n",
    "    # Metrics\n",
    "    def sharpe(r, risk_free=0.06/252):\n",
    "        excess = r - risk_free\n",
    "        return (excess.mean() / excess.std() * math.sqrt(252)) if excess.std() > 0 else 0\n",
    "\n",
    "    cum_strat = (1 + strat_returns).cumprod()\n",
    "    cum_bh    = (1 + buy_hold).cumprod()\n",
    "\n",
    "    return {\n",
    "        'total_return_strategy': round((cum_strat.iloc[-1] - 1) * 100, 2),\n",
    "        'total_return_buy_hold': round((cum_bh.iloc[-1] - 1) * 100, 2),\n",
    "        'sharpe_strategy':       round(sharpe(strat_returns), 3),\n",
    "        'sharpe_buy_hold':       round(sharpe(buy_hold), 3),\n",
    "        'cum_strat':             cum_strat,\n",
    "        'cum_bh':                cum_bh,\n",
    "    }\n",
    "\n",
    "\n",
    "print('RSI Strategy Backtest Results:')\n",
    "print('=' * 65)\n",
    "print(f'{\"Stock\":10} {\"Strat Return\":>14} {\"B&H Return\":>12} {\"Strat Sharpe\":>14} {\"B&H Sharpe\":>12}')\n",
    "print('-' * 65)\n",
    "\n",
    "backtest_results = {}\n",
    "for name, df in stock_data.items():\n",
    "    res = backtest_rsi_strategy(df)\n",
    "    backtest_results[name] = res\n",
    "    print(f'{name:10} {res[\"total_return_strategy\"]:>13.2f}% {res[\"total_return_buy_hold\"]:>11.2f}%'\n",
    "          f' {res[\"sharpe_strategy\"]:>14.3f} {res[\"sharpe_buy_hold\"]:>12.3f}')"
   ]
  },
