    "# ═══════════════════════════════════\n",
    "# SECTION 7: FINAL SUMMARY TABLE\n",
    "# ═══════════════════════════════════\n",
    "\n",
    "summary_rows = []\n",
    "for name, df in stock_data.items():\n",
    "    close  = df['Close']\n",
    "    returns = close.pct_change().dropna()\n",
    "    annual_vol   = returns.std() * math.sqrt(252) * 100\n",
    "    total_return = (close.iloc[-1] / close.iloc[0] - 1) * 100\n",
    "    max_dd       = ((close / close.cummax()) - 1).min() * 100\n",
    "\n",
    "    res = backtest_results[name]\n",
    "    summary_rows.append({\n",
    "        'Stock':          name,\n",
    "        'Total Return':   f'{total_return:.1f}%',\n",
    "        'Annual Vol':     f'{annual_vol:.1f}%',\n",
    "        'Max Drawdown':   f'{max_dd:.1f}%',\n",
    "        'Strat Return':   f'{res[\"total_return_strategy\"]}%',\n",
    "        'Strat Sharpe':   f'{res[\"sharpe_strategy\"]}',\n",
    "    })\n",
    "\n",
    "summary_df = pd.DataFrame(summary_rows).set_index('Stock')\n",
    "print('\\n' + '='*60)\n",
    "print('FINAL SUMMARY — All Stocks')\n",
    "print('='*60)\n",
    "print(summary_df.to_string())\n",
    "print('\\n✓ Notebook complete. See Notebook 1 for LSTM/Prophet/ARIMA training.')"
   ]
  }
