    "# ── Strategy vs Buy-and-Hold chart ──\n",
    "stock_name = 'NIFTY'   # Change to any stock in STOCKS dict\n",
    "res = backtest_results[stock_name]\n",
    "\n",
    "fig = go.Figure()\n",
    "fig.add_trace(go.Scatter(y=res['cum_strat'], name='RSI Strategy', line=dict(color=ACCENT, width=2)))\n",
    "fig.add_trace(go.Scatter(y=res['cum_bh'],    name='Buy & Hold',   line=dict(color=ACCENT2, width=2, dash='dot')))\n",
    "fig.add_hline(y=1.0, line_dash='dot', line_color='rgba(255,255,255,0.2)')\n",
    "\n",
    "fig.update_layout(\n",
    "    title=f'{stock_name} — RSI Strategy vs Buy & Hold (Cumulative Return)',\n",
    "    template='plotly_dark', paper_bgcolor='#0d1117', plot_bgcolor='#0d1117',\n",
    "    height=400, yaxis_title='Growth of ₹1',\n",
    "    font=dict(family='monospace', size=11)\n",
    ")\n",
    "fig.show()"
   ]
