# ============================================================
# AI Stock Market Forecasting — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS — set to your frontend domain in production
# Example: https://my-stockvision.vercel.app
CORS_ORIGINS=*

# Model Settings
LSTM_WINDOW_SIZE=60
LSTM_FORECAST_DAYS=7
LSTM_EPOCHS=20
LSTM_BATCH_SIZE=32
LSTM_USE_CACHE=true       # Load saved weights instead of retraining

# Data Settings
DEFAULT_PERIOD=2y          # yfinance period: 1y, 2y, 5y, max
DEFAULT_INTERVAL=1d        # 1d, 1h, 5m (5m limited to 60 days)

# Chart Vision Settings
MAX_UPLOAD_SIZE_MB=10

# Optional: Alpha Vantage API key for additional data sources
# ALPHA_VANTAGE_KEY=your_key_here

# Optional: Pushover / Slack webhook for signal alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# Logging
LOG_LEVEL=INFO
